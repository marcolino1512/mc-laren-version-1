# ============================================================
# Projeto Beta — Variáveis de ambiente do back-end
# Copie este arquivo para ".env" e preencha os valores reais
# NUNCA faça commit do arquivo .env
# ============================================================

PORT=3000

# Banco de dados MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=SUA_SENHA_MYSQL
DB_NAME=projeto_beta

# Segredo do JWT — use uma string longa e aleatória (mínimo 32 chars)
# Gere um: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=COLOQUE_AQUI_UMA_STRING_LONGA_E_ALEATORIA

# E-mail do administrador mestre (usado pelo seed.js)
ADMIN_EMAIL=seu@email.com
